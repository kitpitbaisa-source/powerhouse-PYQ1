# Azure Cosmos DB credentials
COSMOS_ENDPOINT="https://your-cosmos-db.documents.azure.com:443/"
COSMOS_KEY="your-cosmos-key"

# Secret key that protects all /api/admin/* routes.
# Generate a long random value and set the SAME value in your local .env
# and in the Vercel dashboard (Settings > Environment Variables).
ADMIN_API_KEY="generate-a-long-random-secret"
