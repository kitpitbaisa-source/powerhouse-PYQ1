# Azure Cosmos DB credentials
COSMOS_ENDPOINT="https://your-cosmos-db.documents.azure.com:443/"
COSMOS_KEY="your-cosmos-key"

# Secret key that protects all /api/admin/* routes.
# Generate a long random value and set the SAME value in your local .env
# and in the Vercel dashboard (Settings > Environment Variables).
ADMIN_API_KEY="generate-a-long-random-secret"

# Razorpay payment gateway credentials
# Dashboard > Settings > API Keys. Use rzp_test_* keys for testing,
# rzp_live_* for production. Set the SAME values in the Vercel dashboard.
# The secret must NEVER be committed or exposed to the browser.
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
# Optional: set after creating a webhook in the Razorpay dashboard
RAZORPAY_WEBHOOK_SECRET=""
